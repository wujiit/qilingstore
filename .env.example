APP_NAME="Qiling Medspa System"
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost:8088
CORS_ALLOWED_ORIGINS=
INSTALL_ALLOW_REINSTALL=false
TRUST_PROXY_HEADERS=false
